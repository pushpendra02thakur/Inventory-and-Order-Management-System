# ─────────────────────────────────────────────────
# TraceHub – Environment Variable Reference
# ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# For Railway deployment, add these as Railway env vars.
# For Netlify deployment, add VITE_API_URL only.

# ── PostgreSQL Database ───────────────────────────
# For Railway: Use the DATABASE_URL provided by Railway PostgreSQL plugin
DATABASE_URL=postgresql://postgres:password@localhost:5432/tracehub_db

# Individual DB vars (used if DATABASE_URL is not set)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tracehub_db

# ── JWT Security ──────────────────────────────────
# Generate strong secrets: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_super_secret_jwt_key_change_in_production_min_32_chars
REFRESH_SECRET_KEY=your_super_secret_refresh_key_change_in_production_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────
# Set to your Netlify frontend URL in production
CORS_ORIGINS=["https://your-app.netlify.app","http://localhost:3000"]

# ── Frontend (Netlify env var) ────────────────────
# Set this in Netlify Dashboard → Site Settings → Environment Variables
VITE_API_URL=https://your-backend.up.railway.app
